{
  "name": "web-app",
  "version": "1.0.0",
  "description": "Market Watcher Web Application",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:css && npm run build:server && npm run build:client",
    "build:css": "tailwindcss -i frontend/src/styles.css -o public/assets/app.css --minify",
    "build:server": "tsc",
    "build:client": "esbuild frontend/src/main.tsx --bundle --platform=browser --format=iife --jsx=automatic --outfile=public/assets/app.js --sourcemap --minify",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:client": "esbuild frontend/src/main.tsx --bundle --platform=browser --format=iife --jsx=automatic --outfile=public/assets/app.js --sourcemap --watch",
    "dev:css": "tailwindcss -i frontend/src/styles.css -o public/assets/app.css --watch",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "prom-client": "^15.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.4",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.4",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
